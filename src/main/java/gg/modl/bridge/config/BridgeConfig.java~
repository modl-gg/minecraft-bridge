package gg.modl.bridge.config;

import lombok.RequiredArgsConstructor;
import org.bukkit.configuration.file.FileConfiguration;

import java.util.Collections;
import java.util.List;

@RequiredArgsConstructor
public class BridgeConfig {

    private static final String KEY_API_KEY = "api-key";
    private static final String KEY_DEBUG = "debug";
    private static final String KEY_ANTICHEAT_NAME = "anticheat-name";
    private static final String KEY_SERVER_NAME = "server-name";
    private static final String KEY_BAN_TYPE_ORDINAL = "ban-type-ordinal";
    private static final String KEY_KICK_TYPE_ORDINAL = "kick-type-ordinal";
    private static final String KEY_REPORT_COOLDOWN = "report-cooldown";
    private static final String KEY_THRESHOLD_DEFAULT = "report-violation-threshold.default";
    private static final String KEY_THRESHOLD_CHECKS_PREFIX = "report-violation-threshold.checks.";
    private static final String KEY_STAT_WIPE_COMMANDS = "stat-wipe-commands";
    private static final String KEY_QUERY_ENABLED = "query-enabled";
    private static final String KEY_QUERY_PORT = "query-port";
    private static final String PLACEHOLDER_API_KEY = "your-api-key-here";

    private static final int DEFAULT_BAN_TYPE_ORDINAL = 14;
    private static final int DEFAULT_KICK_TYPE_ORDINAL = 0;
    private static final int DEFAULT_REPORT_COOLDOWN = 60;
    private static final int DEFAULT_VIOLATION_THRESHOLD = 10;
    private static final int DEFAULT_QUERY_PORT = 25590;

    private final FileConfiguration config;

    public String getApiKey() {
        return config.getString(KEY_API_KEY, "");
    }

    public boolean isDebug() {
        return config.getBoolean(KEY_DEBUG, false);
    }

    public String getAnticheatName() {
        return config.getString(KEY_ANTICHEAT_NAME, "Anti-cheat");
    }

    public String getServerName() {
        return config.getString(KEY_SERVER_NAME, "Server 1");
    }

    public int getBanTypeOrdinal() {
        return config.getInt(KEY_BAN_TYPE_ORDINAL, DEFAULT_BAN_TYPE_ORDINAL);
    }

    public int getKickTypeOrdinal() {
        return config.getInt(KEY_KICK_TYPE_ORDINAL, DEFAULT_KICK_TYPE_ORDINAL);
    }

    public int getReportCooldown() {
        return config.getInt(KEY_REPORT_COOLDOWN, DEFAULT_REPORT_COOLDOWN);
    }

    public int getReportViolationThreshold(String checkName) {
        String checkPath = KEY_THRESHOLD_CHECKS_PREFIX + checkName.toLowerCase();
        return config.contains(checkPath)
                ? config.getInt(checkPath)
                : config.getInt(KEY_THRESHOLD_DEFAULT, DEFAULT_VIOLATION_THRESHOLD);
    }

    public List<String> getStatWipeCommands() {
        List<String> commands = config.getStringList(KEY_STAT_WIPE_COMMANDS);
        return commands != null ? commands : Collections.emptyList();
    }

    public boolean isQueryEnabled() {
        return config.getBoolean(KEY_QUERY_ENABLED, true);
    }

    public int getQueryPort() {
        return config.getInt(KEY_QUERY_PORT, DEFAULT_QUERY_PORT);
    }

    public boolean isValid() {
        String apiKey = getApiKey();
        return !apiKey.isEmpty() && !apiKey.equals(PLACEHOLDER_API_KEY);
    }
}
